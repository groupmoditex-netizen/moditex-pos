# ══════════════════════════════════════════════════════════
# MODITEX POS — Variables de entorno
# ══════════════════════════════════════════════════════════
#
# Copia estas variables en:
#   - Vercel → Tu proyecto → Settings → Environment Variables
#   - Local  → crea un archivo .env.local (nunca lo subas a GitHub)
#
# ══════════════════════════════════════════════════════════

# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co

# Anon Key (pública) — Supabase → Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Service Role Key (secreta, SOLO para el servidor)
# ⚠️  NUNCA uses NEXT_PUBLIC_ para esta — quedaría expuesta en el browser
# Supabase → Settings → API → Project API keys → service_role
SUPABASE_SERVICE_KEY=tu_service_role_key_aqui

# Tasa de conversión USD / USDT → EUR
# Actualiza este valor cuando cambie el tipo de cambio
# Ejemplo: si 1 USD = 0.92 EUR, pon 0.92
USD_EUR_RATE=0.93
