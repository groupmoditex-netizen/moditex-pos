# ══════════════════════════════════════════════════════════
# MODITEX POS — Variables de entorno para Vercel
# ══════════════════════════════════════════════════════════
#
# Copia estas variables en:
#   Vercel → Tu proyecto → Settings → Environment Variables
#
# ¡IMPORTANTE! No subas este archivo a GitHub con los valores reales.
#
# ══════════════════════════════════════════════════════════

# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://byoweugcuoeowkfwcnwo.supabase.co

# Anon Key (pública) — la ves en Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Service Role Key (secreta, solo para server) — Supabase → Settings → API
# ⚠️ NUNCA la expongas en el frontend
SUPABASE_SERVICE_KEY=tu_service_role_key_aqui
